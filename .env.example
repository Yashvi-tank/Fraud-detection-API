# Application
APP_NAME=Fraud Detection API
APP_VERSION=1.0.0
DEBUG=false

# PostgreSQL container credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fraud_detection

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fraud_detection

# Behavioral fraud — velocity detection
VELOCITY_SHORT_WINDOW_MINUTES=2
VELOCITY_SHORT_WINDOW_MAX_COUNT=3
VELOCITY_SHORT_WINDOW_SCORE=20
VELOCITY_LONG_WINDOW_MINUTES=10
VELOCITY_LONG_WINDOW_MAX_COUNT=5
VELOCITY_LONG_WINDOW_SCORE=15

# Behavioral fraud — country change detection
COUNTRY_CHANGE_SCORE=20

# Behavioral fraud — device history
NEW_DEVICE_SCORE=15

# Behavioral fraud — spending pattern
SPENDING_ANOMALY_MIN_PRIOR_TRANSACTIONS=3
SPENDING_ANOMALY_MULTIPLIER=3.0
SPENDING_ANOMALY_SCORE=25
